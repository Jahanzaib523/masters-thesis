# Core
APP_NAME="Semantic Authentication System (SAS)"
APP_VERSION="0.1.0"

# Database
DATABASE_URL="sqlite:///./sas.db"

# Use HuggingFace sentence-transformers locally by default
EMBEDDING_PROVIDER="hf"
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
SIMILARITY_THRESHOLD=0.7
MAX_LOGIN_ATTEMPTS=3

# Groq Cloud (for LLM-based semantic scoring, optional)
GROQ_API_KEY=""
GROQ_MODEL_ID="llama-3.3-70b-versatile"

SAS_ENCRYPTION_KEY="="
JWT_SECRET_KEY="(random long secret)"

# OpenAI API Key
OPENAI_API_KEY="sk-proj-Uo---"
OPENAI_MODEL="gpt-4o-mini"

# Leave unset or set to your hf_... token. Empty HF_API_TOKEN="" can prevent registration image generation.
# HF_API_TOKEN=""
# HF_TOKEN=""
IMAGE_PROVIDER="hf"
# Image generation now goes through HF Inference Providers (fal-ai, replicate, etc.).
# FLUX is supported via providers; legacy api-inference.huggingface.co is no longer used.
IMAGE_MODEL="black-forest-labs/FLUX.1-schnell"
# "auto" picks the first available provider for the model; override e.g. "fal-ai", "replicate", "together".
IMAGE_INFERENCE_PROVIDER="auto"
IMAGE_SIZE=1024x1024